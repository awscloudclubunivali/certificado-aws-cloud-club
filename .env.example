# Copie este arquivo para .env e preencha com suas credenciais.
# O arquivo .env nunca deve ser commitado (já está no .gitignore).

# ── Modo de geração ──────────────────────────────────────────────────────────
# Valores aceitos: participante | organizador
MODE=

# ── Configuração SMTP ────────────────────────────────────────────────────────
# Se as variáveis SMTP não estiverem definidas, o envio de email é ignorado.

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Opcional: endereço remetente exibido no email (padrão: SMTP_USER)
# SMTP_FROM=noreply@awscloudclub.com
